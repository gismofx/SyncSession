{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "SyncSystem": "Information"
    }
  },
  "DatabaseProvider": "MySQL",
  "ConnectionStrings": {
    "SyncDatabase": "Server=production-db-server;Database=SyncDb;User=sync_user;Password=CHANGE_ME_IN_PRODUCTION;AllowPublicKeyRetrieval=true;SslMode=Required;"
  },
  "SyncConfiguration": {
    "PushSharedTableThreshold": 10000,
    "PullSharedTableThreshold": 10000,
    "SessionActivityTimeoutMinutes": 30,
    "SharedTableCleanupIntervalMinutes": 60,
    "OrphanedTableCleanupDays": 1,
    "QueuePollIntervalSeconds": 5,
    "SessionRetentionDays": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "https://app.yourdomain.com",
      "https://mobile.yourdomain.com"
    ]
  }
}
