{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/syncsystem-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "DatabaseLogging": {
    "Enabled": false,
    "ConnectionString": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "SyncSystem": "Debug"
    }
  },
  "AllowedHosts": "*",
  "DatabaseProvider": "MySQL",
  "ConnectionStrings": {
    "SyncDatabase": "OVERRIDE_WITH_USER_SECRETS"
  },
  "SyncConfiguration": {
    "PushSharedTableThreshold": 10000,
    "PullSharedTableThreshold": 10000,
    "SessionActivityTimeoutMinutes": 30,
    "SharedTableCleanupIntervalMinutes": 60,
    "OrphanedTableCleanupDays": 1,
    "QueuePollIntervalSeconds": 5,
    "SessionRetentionDays": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "https://app.example.com",
      "https://mobile.example.com"
    ]
  }
}
