{
  "SyncSystem": {
    "RequireAuthorization": false
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "System": "Information",
        "SyncSystem": "Debug",
        "SyncSystem.Server.BackgroundServices": "Verbose"
      }
    }
  },
  "DatabaseLogging": {
    "Enabled": true,
    "ConnectionString": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "SyncSystem": "Debug",
      "SyncSystem.Server.BackgroundServices": "Trace"
    }
  },
  "SyncConfiguration": {
    "QueuePollIntervalSeconds": 2,
    "SessionActivityTimeoutMinutes": 5,
    "SessionRetentionDays": 7,
    "SharedTableCleanupIntervalMinutes": 15
  }
}
