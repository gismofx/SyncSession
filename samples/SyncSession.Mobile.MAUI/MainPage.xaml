<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SyncSystem.Samples.Mobile.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Spacing="25"
            Padding="30,0"
            VerticalOptions="Center">

            <Label
                Text="SyncSystem Mobile"
                SemanticProperties.HeadingLevel="Level1"
                FontSize="32"
                HorizontalOptions="Center" />

            <Label
                Text="Client ID:"
                FontSize="18"
                FontAttributes="Bold" />

            <Label
                x:Name="ClientIdLabel"
                FontSize="14" />

            <Label
                Text="Last Sync:"
                FontSize="18"
                FontAttributes="Bold" />

            <Label
                x:Name="LastSyncLabel"
                Text="Never"
                FontSize="14" />

            <Button
                x:Name="SyncBtn"
                Text="Synchronize"
                FontSize="18"
                Clicked="OnSyncClicked"
                HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
